public fn classify(int32 value) -> string {
    if (value >= 10) {
        return "high";
    } else {
        return "low";
    }
}

public fn main() -> int32 {
    int32 i = 0;
    int32 total = 0;

    while (i < 8) {
        i = i + 1;
        if (i == 2) {
            continue;
        }
        total = total + i;
        if (total > 20) {
            break;
        }
    }

    print("class: " + classify(total));
    print("total: " + total.ToString());
    return 0;
}
