public fn square(int32 value) -> int32 {
    return value * value;
}

public fn mix(int32 left, int32 right) -> int32 {
    if (left > right) {
        return left - right;
    }
    return left + right;
}

public fn accumulate(int32 count) -> int32 {
    int32 i = 0;
    int32 total = 0;
    while (i < count) {
        total = total + square(i);
        i = i + 1;
    }
    return total;
}

public fn main() -> int32 {
    int32 value = accumulate(6);
    int32 mixed = mix(value, 10);
    print("link: " + mixed.ToString());
    return 0;
}

